        {
            "parameters": {
                "jsCode": "const inputData = $('Validacao dos Dados').first().json;\n\nlet evoResp, success, evoMessageId, errorDetail;\n\ntry {\n  evoResp = $input.first().json;\n  \n  if (evoResp.error || evoResp.status >= 400 || evoResp.errorMessage) {\n    success = false;\n    evoMessageId = null;\n    const rawError = evoResp.response?.message || evoResp.error || evoResp.message || evoResp.errorMessage || JSON.stringify(evoResp);\n    const arr = Array.isArray(rawError) ? rawError.flat() : [rawError];\n    errorDetail = arr.join(' | ');\n  } else {\n    evoMessageId = evoResp.key?.id || evoResp.id || evoResp.messageId || null;\n    success = !!evoMessageId;\n    errorDetail = success ? null : 'Sem messageId na resposta: ' + JSON.stringify(evoResp);\n  }\n} catch(e) {\n  success = false;\n  evoMessageId = null;\n  errorDetail = 'Erro interno: ' + e.message;\n}\n\nlet friendlyError = null;\nif (!success) {\n  const type = inputData.type || 'arquivo';\n  if (errorDetail && errorDetail.includes('mimetype')) {\n    friendlyError = 'Formato de ' + type + ' não suportado pelo WhatsApp.';\n  } else if (errorDetail && errorDetail.includes('media')) {\n    friendlyError = 'Não foi possível enviar a mídia. Verifique o formato do arquivo.';\n  } else {\n    friendlyError = 'Não foi possível enviar a mensagem via WhatsApp.';\n  }\n}\n\nconst metadata = {\n  whatsapp_message_id: evoMessageId,\n  instancia: 'DraIsabela',\n  numero_destino: inputData.to,\n  media_url: inputData.mediaUrl || null,\n  media_name: inputData.mediaName || null,\n  negocio_id: inputData.negocioId,\n  enviado_em: new Date().toISOString(),\n  erro: errorDetail\n};\n\nreturn [{\n  json: {\n    success,\n    evoMessageId,\n    conversationId: inputData.conversationId,\n    senderId:       inputData.senderId,\n    contentType:    inputData.type,\n    content:        inputData.text || inputData.caption || null,\n    metadata,\n    timestamp:      inputData.timestamp,\n    errorDetail,\n    friendlyError\n  }\n}];"
            },
