            "parameters": {
                "jsCode": "const body = $input.first().json.body;\nif (!body.negocioId) throw new Error('Campo negocioId ausente');\nif (!body.leadId)    throw new Error('Campo leadId ausente');\nif (!body.clinicId)  throw new Error('Campo clinicId ausente');\nif (!body.to)        throw new Error('Campo to ausente');\nif (!body.type)      throw new Error('Campo type ausente');\n\n// Mapeamento de tipos alternativos enviados pelo frontend\nconst tipoMap = {\n  'file': 'image',\n  'photo': 'image',\n  'picture': 'image',\n  'voice': 'audio',\n  'mp3': 'audio',\n  'ogg': 'audio',\n  'mp4': 'video',\n  'pdf': 'document',\n  'doc': 'document',\n  'docx': 'document',\n};\nconst type = tipoMap[body.type] || body.type;\n\nconst validTypes = ['text', 'audio', 'image', 'document', 'video'];\nif (!validTypes.includes(type)) {\n  throw new Error('Tipo invalido: ' + body.type);\n}\nif (type === 'text' && !body.text) {\n  throw new Error('Campo text obrigatorio para tipo text');\n}\nif (['audio', 'image', 'document', 'video'].includes(type)) {\n  if (!body.mediaUrl && !body.mediaBase64 && !body.fileContent) {\n    throw new Error('Para tipo ' + type + ', envie mediaUrl, mediaBase64 ou fileContent');\n  }\n}\n\n// Se veio fileContent (base64 raw), converte para mediaBase64\nconst mediaBase64 = body.mediaBase64 || body.fileContent || null;\n\nreturn [{\n  json: {\n    negocioId:     body.negocioId,\n    leadId:        body.leadId,\n    clinicId:      body.clinicId,\n    senderId:      body.senderId || null,\n    to:            body.to,\n    type:          type,\n    text:          body.text || null,\n    mediaUrl:      body.mediaUrl || null,\n    mediaBase64:   mediaBase64,\n    mediaName:     body.mediaName || body.fileName || null,\n    mediaMimetype: body.mediaMimetype || null,\n    caption:       body.caption || null,\n    timestamp:     body.timestamp || new Date().toISOString()\n  }\n}];"
            },
