            "parameters": {
                "jsCode": "const input = $input.first().json;\nconst validData = $('Validacao dos Dados').first().json;\n\nlet conversationId = null;\n\nif (Array.isArray(input)) {\n  conversationId = input.length > 0 ? input[0].id : null;\n} else if (input && input.id) {\n  conversationId = input.id;\n} else {\n  conversationId = null;\n}\n\nreturn [{\n  json: {\n    ...validData,\n    conversationId,\n    needsCreate: !conversationId\n  }\n}];"
            },
