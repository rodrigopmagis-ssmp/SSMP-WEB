            "parameters": {
                "jsCode": "const validData = $('Validacao dos Dados').first().json;\nlet conversationId;\n\ntry {\n  const created = $('Criar Conversation').first().json;\n  conversationId = created.id || null;\n} catch(e) {\n  conversationId = null;\n}\n\nif (!conversationId) {\n  conversationId = $('Tem Conversation?').first().json.conversationId;\n}\n\nif (!conversationId) {\n  throw new Error('Nao foi possivel obter ou criar conversation. leadId: ' + validData.leadId);\n}\n\nreturn [{\n  json: {\n    ...validData,\n    conversationId\n  }\n}];"
            },
